{
  "pluginAlias": "HCPBridgeMqttHomebridgePlugin",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "GarageDoor"
      },
      "displayName": {
        "type": "string",
        "title": "Accessory Display Name",
        "placeholder": "Garage Door",
        "default": "Garage Door",
        "description": "Name shown in the Home app"
      },
      "enableLamp": {
        "type": "boolean",
        "title": "Enable Lamp Accessory",
        "description": "Expose the garage lamp as a Lightbulb in HomeKit",
        "default": false
      },
      "enableVent": {
        "type": "boolean",
        "title": "Enable Vent Switch Accessory",
        "description": "Expose a switch to control the venting position",
        "default": false
      },
      "ventDisplayName": {
        "type": "string",
        "title": "Vent Switch Display Name",
        "placeholder": "Garage Vent",
        "description": "Name shown in the Home app for the vent switch tile"
      },
      "mqttHost": {
        "type": "string",
        "title": "URL",
        "description": "MQTT broker URL default: mqtt://localhost:1883",
        "placeholder": "mqtt://localhost:1883",
        "default": "mqtt://localhost:1883"
      },
      "mqttUsername": {
        "type": "string",
        "title": "Username",
        "description": "MQTT Username (optional)"
      },
      "mqttPassword": {
        "type": "string",
        "title": "Password",
        "description": "MQTT Password (optional)"
      },
      "mqttClientID": {
        "type": "string",
        "title": "ClientID",
        "description": "MQTT Client ID (optional, default: HomeBridge)"
      }
    },
    "required": [
      "name"
    ]
  },
  "layout": [
    {
      "type": "fieldset",
      "title": "General",
      "items": [
        "name",
        "displayName",
        "enableLamp",
        "enableVent",
        "ventDisplayName"
      ]
    },
    {
      "type": "fieldset",
      "title": "MQTT Broker",
      "items": [
        "mqttHost",
        "mqttUsername",
        "mqttPassword",
        "mqttClientID"
      ]
    }
  ]
}