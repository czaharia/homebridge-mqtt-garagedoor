{
  "private": false,
  "displayName": "Homebridge HCPBridgeMQTT",
  "name": "homebridge-hcpbridgemqtt",
  "version": "0.2.6",
  "description": "A Homebridge plugin for HCPBridgeMqtt (Hormann garage door controller)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:czaharia/homebridge-hcpbridgemqtt.git"
  },
  "homepage": "https://github.com/czaharia/homebridge-hcpbridgemqtt",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "HCPBridgeMqtt",
    "hormann",
    "garage",
    "mqtt"
  ],
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0-beta.0",
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "prebuild": "echo \"export const PLUGIN_VERSION = '`jq -r '.version' < package.json`';\" > ./src/version.ts",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "mqtt",
    "garage",
    "door"
  ],
  "dependencies": {
    "mqtt": "^5.8.1",
    "mqtt-packet": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "homebridge": "^1.7.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.2.5",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.5"
  }
}
